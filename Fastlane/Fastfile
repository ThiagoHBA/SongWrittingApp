require "fileutils"
require "json"
require "shellwords"

COVERAGE_OUTPUT_DIR = "coverage_output"
COVERAGE_REPORT_PATH = File.join(COVERAGE_OUTPUT_DIR, "report.json")
COVERAGE_BADGE_PATH = File.join(COVERAGE_OUTPUT_DIR, "coverage_badge.json")
COVERAGE_TARGET_NAME = "Main.app"

def coverage_percentage(report)
  return report["coverage_percentage"].to_f if report.key?("coverage_percentage")
  return report["covered_percent"].to_f if report.key?("covered_percent")

  target = Array(report["targets"]).find { |item| item["name"] == COVERAGE_TARGET_NAME } || Array(report["targets"]).first
  if target
    return target["coverage"].to_f * 100 if target.key?("coverage")
    return target["lineCoverage"].to_f * 100 if target.key?("lineCoverage")
  end

  return report["coverage"].to_f * 100 if report.key?("coverage")
  return report["lineCoverage"].to_f * 100 if report.key?("lineCoverage")

  0.0
end

def write_coverage_badge(coverage_pct)
  coverage_ratio = coverage_pct / 100.0

  File.write(COVERAGE_BADGE_PATH, JSON.generate({
    schemaVersion: 1,
    label: "coverage",
    message: "#{coverage_pct.round(1)}%",
    color: coverage_ratio > 0.7 ? "brightgreen" : coverage_ratio > 0.5 ? "yellow" : "red"
  }))
end

def write_coverage_outputs(xcresult_path)
  UI.user_error!("Missing xcresult bundle at #{xcresult_path}") unless xcresult_path && File.directory?(xcresult_path)

  FileUtils.mkdir_p(COVERAGE_OUTPUT_DIR)

  report = JSON.parse(
    sh("xcrun xccov view --report --json #{Shellwords.escape(xcresult_path)}", log: false)
  )
  report["coverage_percentage"] = coverage_percentage(report)

  File.write(COVERAGE_REPORT_PATH, JSON.pretty_generate(report))
  write_coverage_badge(report["coverage_percentage"])
end

default_platform(:ios)

platform :ios do

  desc "Run tests and get coverage"
  lane :coverage do
    run_tests(
      scheme: "Main",
      device: "iPhone 16",
      code_coverage: true,
      output_directory: "test_output",
      result_bundle: true,
      xcargs: "-skipMacroValidation"
    )

    xcov(
      scheme: "Main",
      output_directory: "coverage_output",
      html_report: true,
      json_report: true,
      minimum_coverage_percentage: 60.0,
      include_targets: COVERAGE_TARGET_NAME
    )

    xcresult_path = Actions.lane_context[SharedValues::SCAN_GENERATED_XCRESULT_PATH] || "test_output/Main.xcresult"
    write_coverage_outputs(xcresult_path)
  end
end
